#!/usr/bin/env sh
# .husky/pre-commit
# 커밋 직전 실행 — 실패 시 커밋 차단
#
# 검사 항목:
#   1. staged 파일 ESLint + Prettier (lint-staged)
#   2. TypeScript 전체 타입 체크
#   3. 변경된 파일과 연관된 Jest 테스트

. "$(dirname "$0")/_/husky.sh"

echo ""
echo "🔍 pre-commit 검사 시작..."
echo ""

# ──────────────────────────────────────────
# Step 1. lint-staged (ESLint + Prettier)
# staged 파일에만 실행하므로 빠름
# ──────────────────────────────────────────
echo "▶ Step 1/3  ESLint + Prettier (staged 파일)"
pnpm lint-staged
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ [차단] ESLint 또는 Prettier 검사 실패"
  echo "   위 오류를 수정한 뒤 다시 커밋해주세요."
  echo ""
  exit 1
fi
echo "   ✅ 통과"
echo ""

# ──────────────────────────────────────────
# Step 2. TypeScript 타입 체크
# lint-staged는 파일 단위라 타입 체크를 별도로 실행
# ──────────────────────────────────────────
echo "▶ Step 2/3  TypeScript 타입 체크"
pnpm type-check
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ [차단] TypeScript 타입 에러가 있습니다."
  echo "   위 타입 에러를 수정한 뒤 다시 커밋해주세요."
  echo ""
  exit 1
fi
echo "   ✅ 통과"
echo ""

# ──────────────────────────────────────────
# Step 3. 관련 Jest 테스트 실행
# staged 파일과 연관된 테스트만 실행 (--findRelatedTests)
# ──────────────────────────────────────────
echo "▶ Step 3/3  Jest 테스트 (변경 파일 연관)"

# staged 파일 목록 추출 (.ts .tsx .js .jsx 만)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | tr '\n' ' ')

if [ -n "$STAGED_FILES" ]; then
  pnpm jest --passWithNoTests --findRelatedTests --bail $STAGED_FILES
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ [차단] 연관된 테스트가 실패했습니다."
    echo "   테스트를 수정한 뒤 다시 커밋해주세요."
    echo ""
    exit 1
  fi
  echo "   ✅ 통과"
else
  echo "   ⏭  변경된 TS/JS 파일 없음 — 스킵"
fi

echo ""
echo "✅ pre-commit 모든 검사 통과 — 커밋을 진행합니다."
echo ""
